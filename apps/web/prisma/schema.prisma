generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(cuid())
  clerkUserId         String               @unique
  firstName           String
  lastName            String
  email               String               @unique
  phoneNumber         String?
  githubInstallations GithubInstallation[]
  sentryConnection    SentryConnection?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model GithubInstallation {
  id             String       @id @default(cuid())
  installationId Int          @unique
  accountLogin   String
  repos          Repository[]
  clerkUserId    String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [clerkUserId], references: [id])
}

model Repository {
  id             String             @id @default(cuid())
  repoId         Int                @unique
  name           String
  fullName       String
  private        Boolean
  installationId Int
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  installation   GithubInstallation @relation(fields: [installationId], references: [installationId])
  reviews        Review[]
  sentryProject  RepositorySentryProject?
  fixRuns        FixRun[]
}

model Review {
  id                  String       @id @default(cuid())
  repoId              Int
  prNumber            Int
  prTitle             String
  prUrl               String
  prAuthor            String?
  prBody              String?
  headRef             String?
  baseRef             String?
  prState             String?
  prMerged            Boolean      @default(false)
  prDraft             Boolean      @default(false)
  review              String
  status              ReviewStatus @default(completed)
  reviewerClerkUserId String
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  repository          Repository?  @relation(fields: [repositoryId], references: [id])
  repositoryId        String?
  findings            Finding[]

  @@unique([repositoryId, prNumber])
}

model Finding {
  id             String   @id @default(cuid())
  reviewId       String
  review         Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  severity       String
  file           String
  line           Int?
  quote          String?
  title          String
  message        String
  suggestion     String?
  postedToGitHub Boolean  @default(false)
  skipReason     String?
  createdAt      DateTime @default(now())
}

enum ReviewStatus {
  pending
  completed
  failed
}

model SentryConnection {
  id                String   @id @default(cuid())
  userId            String   @unique
  accessTokenCipher String
  tokenType         String
  scope             String?
  sentryUserId      String?
  sentryEmail       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RepositorySentryProject {
  id               String     @id @default(cuid())
  repositoryId     String     @unique
  sentryOrgSlug    String
  sentryProjectSlug String
  environment      String?
  enabled          Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  repository       Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
}

model FixRun {
  id           String        @id @default(cuid())
  issueId      String
  issueTitle   String
  repoId       String
  status       FixRunStatus  @default(running)
  prUrl        String?
  branchName   String?
  summary      String?
  rootCause    String?
  filesChanged Json?
  error        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  repository   Repository    @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  repositoryId String
}

enum ReviewJobStatus {
  pending
  processing
  completed
  failed
}

model ReviewJob {
  id               String           @id @default(cuid())
  installationId   Int
  owner            String
  repo             String
  headRef          String
  baseRef          String
  prNumber         Int
  prTitle          String
  prUrl            String
  prAuthor         String?
  prBody           String?
  clerkUserId      String
  initialDiff      String           @default("")
  filesJson        Json?
  deliveryId       String?
  status           ReviewJobStatus  @default(pending)
  error            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Skill {
  id           String   @id @default(cuid())
  name         String
  useCase      String
  description  String
  content      String
  targetAgents String[]
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, name])
}

enum FixRunStatus {
  running
  success
  failed
}
