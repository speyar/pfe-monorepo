{
  "name": "@ceira/github-sdk-provider",
  "version": "0.1.0",
  "private": true,
  "description": "Vercel AI SDK provider wrapping the GitHub Copilot SDK",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf node_modules dist .turbo"
  },
  "dependencies": {
    "@ai-sdk/provider": "^3.0.0",
    "@ai-sdk/provider-utils": "^4.0.1",
    "vscode-jsonrpc": "^8.2.1"
  },
  "peerDependencies": {
    "@github/copilot": "^0.0.417"
  },
  "peerDependenciesMeta": {
    "@github/copilot": {
      "optional": false
    }
  },
  "devDependencies": {
    "@pfe-monorepo/typescript-config": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^5.9.2",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
