# =============================================================================
# PFE Review Agent + GitHub App + Vercel Sandbox — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in the values required for your setup.
#
# Modes:
# - Local review mode (default): repository exploration runs on local filesystem
# - Sandbox review mode: repository exploration runs inside Vercel Sandbox
#
# IMPORTANT:
# - Sandbox mode is fail-fast: if sandbox provisioning/auth fails, review fails.
# - Private repositories require GitHub App credentials and installation context.
# =============================================================================

# ── Review Agent Execution Mode ──────────────────────────────────────────────
# Enable sandbox execution mode (default: false/local)
# Accepted true values: 1, true, yes
REVIEW_AGENT_USE_SANDBOX=false

# Sandbox runtime image (default: node24)
# Supported examples: node22, node24, python3.13
# REVIEW_AGENT_SANDBOX_RUNTIME=node24

# Maximum sandbox lifetime in seconds (default: 900)
# REVIEW_AGENT_SANDBOX_TIMEOUT_SECONDS=900

# Hard timeout for end-to-end review execution inside sandbox, in milliseconds
# (default: 240000)
# REVIEW_AGENT_SANDBOX_REVIEW_TIMEOUT_MS=240000

# ── Vercel Sandbox Credentials ───────────────────────────────────────────────
# Required when REVIEW_AGENT_USE_SANDBOX=true (unless your environment already
# provides equivalent auth context).
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# ── GitHub App Credentials (Private Repo Clone in Sandbox) ──────────────────
# Required for private repositories in sandbox mode.
# The app must be installed on the target repository.
GITHUB_APP_ID=

# Private key for your GitHub App.
# Keep escaped newlines in .env, e.g. "-----BEGIN...\n...\n-----END..."
GITHUB_PRIVATE_KEY=

# ── Review Model Provider (Current setup) ───────────────────────────────────
# Token used by review-agent model provider (Copilot path in current code).
COPILOT_GITHUB_TOKEN=

# Optional model override for CLI script usage.
# REVIEW_AGENT_MODEL=gpt-5.3-codex

# =============================================================================
# Notes
# =============================================================================
# 1) installationId is passed from GitHub webhook payload into review metadata.
# 2) In sandbox mode, review-agent requests a short-lived installation token
#    using GITHUB_APP_ID + GITHUB_PRIVATE_KEY + installationId.
# 3) That token is used to pre-populate sandbox from private git source.
# 4) Repository tools (readFile/listFiles/searchRepository/runCommand) execute
#    inside the sandbox filesystem when sandbox mode is enabled.
# =============================================================================
