generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(cuid())
  clerkUserId         String               @unique
  firstName           String
  lastName            String
  email               String               @unique
  phoneNumber         String?
  githubInstallations GithubInstallation[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model GithubInstallation {
  id             String       @id @default(cuid())
  installationId Int          @unique
  accountLogin   String
  repos          Repository[]
  clerkUserId    String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [clerkUserId], references: [id])
}

model Repository {
  id             String             @id @default(cuid())
  repoId         Int                @unique
  name           String
  fullName       String
  private        Boolean
  installationId Int
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  installation   GithubInstallation @relation(fields: [installationId], references: [installationId])
  reviews        Review[]
}

model Review {
  id                  String       @id @default(cuid())
  repoId              Int
  prNumber            Int
  prTitle             String
  prUrl               String
  review              String
  status              ReviewStatus @default(completed)
  reviewerClerkUserId String
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  repository          Repository?  @relation(fields: [repositoryId], references: [id])
  repositoryId        String?

  @@unique([repositoryId, prNumber])
}

enum ReviewStatus {
  pending
  completed
  failed
}
