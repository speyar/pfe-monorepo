{
  "name": "@pfe-monorepo/review-agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "LLM-powered PR code review agent",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "review": "bun src/scripts/review.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.39",
    "ai": "^5.0.41",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@pfe-monorepo/typescript-config": "workspace:*",
    "@types/node": "^24.5.2"
  }
}
